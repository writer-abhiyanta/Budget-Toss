rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Methods
    function isValidUser(data) {
      let baseValid = data.keys().hasAll(['monthlyBudget', 'createdAt'])
        && data.monthlyBudget is number
        && data.createdAt is number;
        
      let allowedKeys = ['monthlyBudget', 'createdAt', 'weeklyReportEnabled', 'lastReportSent'];
      let hasOnlyAllowedKeys = data.keys().hasOnly(allowedKeys);
      
      let weeklyReportEnabledValid = !((data.keys().hasAny(['weeklyReportEnabled'])) && !(data.weeklyReportEnabled is bool));
      let lastReportSentValid = !((data.keys().hasAny(['lastReportSent'])) && !(data.lastReportSent is number));

      return baseValid && hasOnlyAllowedKeys && weeklyReportEnabledValid && lastReportSentValid;
    }

    function isValidExpense(data) {
      let hasCore = data.keys().hasAll(['amount', 'category', 'description', 'date', 'createdAt', 'paymentProvider'])
        && data.amount is number
        && data.category is string && data.category.size() <= 50
        && data.description is string && data.description.size() <= 200
        && data.date is number
        && data.createdAt is number
        && data.paymentProvider is string && data.paymentProvider.size() <= 20;

      let hasExtended = data.keys().hasAll(['amount', 'category', 'description', 'date', 'createdAt', 'paymentProvider', 'sentiment', 'spendingPattern'])
        && data.keys().size() == 8
        && data.sentiment is string && data.sentiment.size() <= 50
        && data.spendingPattern is string && data.spendingPattern.size() <= 50;

      return (data.keys().size() == 6 && hasCore) || (hasCore && hasExtended);
    }

    function isValidDoNotBuyItem(data) {
      return data.keys().hasAll(['title', 'reason', 'createdAt'])
        && data.keys().size() == 3
        && data.title is string && data.title.size() <= 100
        && data.reason is string && data.reason.size() <= 300
        && data.createdAt is number;
    }

    function isValidBuyLaterItem(data) {
      let baseValid = data.keys().hasAll(['title', 'totalAmount', 'months', 'createdAt'])
        && data.title is string && data.title.size() <= 100
        && data.totalAmount is number
        && data.months is number
        && data.createdAt is number;
        
      let hasOnlyBase = data.keys().size() == 4;
      let hasInterest = data.keys().size() == 5 && data.keys().hasAll(['interestRate']) && data.interestRate is number;
      
      return baseValid && (hasOnlyBase || hasInterest);
    }

    function isValidInvestment(data) {
      let baseValid = data.keys().hasAll(['symbol', 'assetType', 'quantity', 'averagePrice', 'createdAt'])
        && data.symbol is string && data.symbol.size() <= 20
        && data.assetType is string && data.assetType.size() <= 50
        && data.quantity is number
        && data.averagePrice is number
        && data.createdAt is number;

      let allowedKeys = ['symbol', 'assetType', 'quantity', 'averagePrice', 'createdAt', 'targetPrice', 'dropPercentage'];
      let hasOnlyAllowedKeys = data.keys().hasOnly(allowedKeys);

      let targetPriceValid = !((data.keys().hasAny(['targetPrice'])) && !(data.targetPrice is number));
      let dropPercentageValid = !((data.keys().hasAny(['dropPercentage'])) && !(data.dropPercentage is number));

      return baseValid && hasOnlyAllowedKeys && targetPriceValid && dropPercentageValid;
    }

    function isValidCategoryBudget(data) {
      return data.keys().hasAll(['category', 'amount', 'createdAt'])
        && data.keys().size() == 3
        && data.category is string && data.category.size() <= 60
        && data.amount is number
        && data.createdAt is number;
    }

    // Match users
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; // Users shouldn't be listed
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['monthlyBudget', 'weeklyReportEnabled', 'lastReportSent'])
      );

      // Match expenses subcollection
      match /expenses/{expenseId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(expenseId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(expenseId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(expenseId) && isValidExpense(incoming());
        
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(expenseId) && isValidExpense(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'description', 'date', 'paymentProvider', 'sentiment', 'spendingPattern'])
        );
      }

      // Match do_not_buy subcollection
      match /do_not_buy/{itemId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(itemId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(itemId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(itemId) && isValidDoNotBuyItem(incoming());
        allow update: if false; // Immutable, users can only delete and recreate
      }

      // Match buy_later subcollection
      match /buy_later/{itemId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(itemId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(itemId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(itemId) && isValidBuyLaterItem(incoming());
        allow update: if false; // Immutable for now
      }

      // Match category_budgets subcollection
      match /category_budgets/{budgetId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(budgetId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(budgetId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(budgetId) && isValidCategoryBudget(incoming());
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(budgetId) && isValidCategoryBudget(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount'])
        );
      }

      // Match investments subcollection
      match /investments/{investmentId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(investmentId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(investmentId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(investmentId) && isValidInvestment(incoming());
        allow update: if false; // For now immutable, edit by delete + add if necessary (or we can add update logic)
      }
    }
  }
}
